---
import '../styles/global.css';
import { GA4_ID, TRUSTPILOT_BU_ID, SITE_NAME, SITE_URL, SITE_DESCRIPTION, OG_IMAGE, LOGO_IMAGE, FAVICON, LINKEDIN_URL, INSTAGRAM_URL, BOOKING_LINK } from '../lib/constants';
import { getAlternateUrl } from '../i18n/utils';
import CookieBanner from '../react/CookieBanner';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  locale?: string;
  noindex?: boolean;
  jsonLd?: Record<string, any>[];
  articleDate?: string;
  articleModified?: string;
}

const {
  title = `${SITE_NAME} | Growth Marketing Tech B2B & B2C`,
  description = SITE_DESCRIPTION,
  canonical,
  ogImage = OG_IMAGE,
  ogType = 'website',
  locale = 'es',
  noindex = false,
  jsonLd = [],
  articleDate,
  articleModified,
} = Astro.props;

const canonicalUrl = canonical ? new URL(canonical, SITE_URL).href : new URL(Astro.url.pathname, SITE_URL).href;
const lang = locale === 'en' ? 'en' : 'es';
const ogLocale = locale === 'en' ? 'en_US' : 'es_ES';

// Hreflang: only emit English alternate for pages that actually have an English version.
// Currently only the homepage exists in English (/en/).
const esHref = new URL(getAlternateUrl(Astro.url.pathname, 'es'), SITE_URL).href;
const enPath = getAlternateUrl(Astro.url.pathname, 'en');
const ENGLISH_PAGES = new Set(['/en/', '/en']);
const hasEnglishVersion = ENGLISH_PAGES.has(enPath);
const enHref = hasEnglishVersion ? new URL(enPath, SITE_URL).href : null;

// Organization schema - always present (matches existing Next.js exactly)
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Growth4U',
  url: SITE_URL,
  logo: LOGO_IMAGE,
  sameAs: [LINKEDIN_URL, INSTAGRAM_URL],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Preconnect for faster external resource loading -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://i.imgur.com" />

    <!-- Google Fonts - non-render-blocking -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" /></noscript>

    <!-- Title & Description -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Favicon -->
    <link rel="icon" href={FAVICON} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang (i18n) — only emit en alternate when the page exists in English -->
    <link rel="alternate" hreflang="es" href={esHref} />
    {enHref && <link rel="alternate" hreflang="en" href={enHref} />}
    <link rel="alternate" hreflang="x-default" href={esHref} />

    <!-- Robots -->
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta name="robots" content="index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1" />
    )}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={SITE_NAME} />

    <!-- Article dates (for blog posts) -->
    {articleDate && <meta property="article:published_time" content={articleDate} />}
    {articleModified && <meta property="article:modified_time" content={articleModified} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Organization Schema (always present) -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

    <!-- Additional JSON-LD schemas (per-page) -->
    {jsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- Leadsy.ai visitor identification -->
    <script is:inline id="vtag-ai-js" async src="https://r2.leadsy.ai/tag.js" data-pid="1ygyGzu59uikZ35L9" data-version="062024"></script>
  </head>
  <body class="antialiased">
    <slot />

    <!-- Cookie Banner (consent-based Meta Pixel) -->
    <CookieBanner client:idle />

    <!-- WebMCP: expose site actions to in-browser AI agents. No-op when navigator.modelContext is absent. -->
    <script is:inline define:vars={{ SITE_URL, BOOKING_LINK }}>
      (function () {
        if (typeof navigator === 'undefined' || !navigator.modelContext || typeof navigator.modelContext.provideContext !== 'function') return;

        const go = (path) => { window.location.href = new URL(path, SITE_URL).href; };

        navigator.modelContext.provideContext({
          tools: [
            {
              name: 'book_consultation',
              description: 'Open the Growth4U consultation booking page to schedule a 30-minute strategy call with the founder.',
              inputSchema: { type: 'object', properties: {}, additionalProperties: false },
              execute: async () => { window.location.href = BOOKING_LINK; return { booking_url: BOOKING_LINK }; },
            },
            {
              name: 'browse_lead_magnets',
              description: 'Navigate to the Growth4U resources page with free lead magnets (frameworks, guides, playbooks on fintech growth).',
              inputSchema: { type: 'object', properties: {}, additionalProperties: false },
              execute: async () => { go('/recursos/'); return { url: SITE_URL + '/recursos/' }; },
            },
            {
              name: 'browse_blog',
              description: 'Navigate to the Growth4U blog — articles on growth marketing, GEO, fintech, and Trust Engine methodology.',
              inputSchema: { type: 'object', properties: {}, additionalProperties: false },
              execute: async () => { go('/blog/'); return { url: SITE_URL + '/blog/' }; },
            },
            {
              name: 'browse_case_studies',
              description: 'Navigate to Growth4U case studies (BNEXT, Bit2Me, GoCardless) with verified growth results.',
              inputSchema: { type: 'object', properties: {}, additionalProperties: false },
              execute: async () => { go('/casos-de-exito/'); return { url: SITE_URL + '/casos-de-exito/' }; },
            },
            {
              name: 'view_service',
              description: 'Navigate to a Growth4U service page: GEO for fintechs, growth marketing fintech, or the Trust Engine methodology.',
              inputSchema: {
                type: 'object',
                properties: {
                  service: {
                    type: 'string',
                    enum: ['geo-para-fintechs', 'growth-marketing-fintech', 'trust-engine'],
                    description: 'Which service page to open.',
                  },
                },
                required: ['service'],
                additionalProperties: false,
              },
              execute: async ({ service }) => {
                const path = `/servicios/${service}/`;
                go(path);
                return { url: SITE_URL + path };
              },
            },
          ],
        });
      })();
    </script>

    <!-- Google Analytics 4 (deferred to after content) -->
    <script is:inline src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`} async></script>
    <script is:inline define:vars={{ GA4_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', GA4_ID);
    </script>

    <!-- Trustpilot Invitation SDK (deferred to after content) -->
    <script is:inline define:vars={{ TRUSTPILOT_BU_ID }}>
      (function(w,d,s,r,n){w.TrustpilotObject=n;w[n]=w[n]||function(){(w[n].q=w[n].q||[]).push(arguments)};
      a=d.createElement(s);a.async=1;a.src=r;a.type='text/java'+s;f=d.getElementsByTagName(s)[0];
      f.parentNode.insertBefore(a,f)})(window,document,'script','https://invitejs.trustpilot.com/tp.min.js','tp');
      tp('register', TRUSTPILOT_BU_ID);
    </script>
  </body>
</html>
