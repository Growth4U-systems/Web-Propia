---
import type { BlogPost } from '../lib/firebase-fetch';

interface Props {
  currentSlug: string;
  currentCategory: string;
  allPosts: BlogPost[];
  maxPosts?: number;
}

const { currentSlug, currentCategory, allPosts, maxPosts = 4 } = Astro.props;

// Select related posts by keyword overlap (title + excerpt) instead of pure
// recency. Spreads internal link equity to semantically-related posts — helps
// Google discover older/less-linked content and build topic clusters.
const STOPWORDS = new Set([
  'de','la','el','y','en','que','los','las','un','una','para','con','por','o','del','al','es','se',
  'a','como','sin','sobre','entre','mas','tu','te','me','su','lo','e','no','si','ya','mi','ser',
  'esta','este','pero','cuando','todo','puede','hay','son','hacer','the','to','and','of','in',
]);

function tokens(str: string): Set<string> {
  return new Set(
    str
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-z0-9\s]/g, ' ')
      .split(/\s+/)
      .filter((w) => w.length > 3 && !STOPWORDS.has(w)),
  );
}

const current = allPosts.find((p) => p.slug === currentSlug);
const currentTokens = tokens(`${current?.title || ''} ${current?.excerpt || ''}`);

const relatedPosts = allPosts
  .filter((p) => p.slug !== currentSlug)
  .map((p) => {
    const t = tokens(`${p.title} ${p.excerpt}`);
    let shared = 0;
    for (const w of t) if (currentTokens.has(w)) shared++;
    const categoryBoost = p.category === currentCategory ? 1 : 0;
    return { post: p, score: shared + categoryBoost * 0.5 };
  })
  .sort((a, b) => b.score - a.score || (b.post.createdAt || '').localeCompare(a.post.createdAt || ''))
  .slice(0, maxPosts)
  .map((x) => x.post);
---

{relatedPosts.length > 0 && (
  <section class="mt-16 pt-10 border-t border-slate-200">
    <h3 class="text-2xl font-bold text-[#032149] mb-8">Artículos relacionados</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {relatedPosts.map((post) => (
        <a href={`/blog/${post.slug}/`} class="group">
          <div class="relative overflow-hidden rounded-xl mb-3 aspect-video bg-slate-100">
            {post.image && (
              <img
                src={post.image}
                alt={post.title}
                class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            )}
            <div class="absolute top-3 left-3 bg-white/90 backdrop-blur px-2 py-1 rounded-full text-xs font-bold text-[#3ecda5] uppercase tracking-wide">
              {post.category}
            </div>
          </div>
          <h4 class="font-bold text-[#032149] group-hover:text-[#3ecda5] transition-colors line-clamp-2 mb-1">{post.title}</h4>
          <p class="text-sm text-slate-500">{post.readTime}</p>
        </a>
      ))}
    </div>
  </section>
)}
