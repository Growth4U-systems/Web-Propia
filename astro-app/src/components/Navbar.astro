---
import { getAlternateUrl, type Locale } from '../i18n/utils';

interface Props {
  t: {
    nav: {
      problem: string;
      results: string;
      methodology: string;
      cases: string;
      team: string;
      blog: string;
      cta: string;
    };
  };
  lang: Locale;
  bookingLink: string;
  currentPath?: string;
}

const { t, lang, bookingLink, currentPath = '/' } = Astro.props;

const langToggleHref = getAlternateUrl(currentPath, lang === 'es' ? 'en' : 'es');
const langToggleLabel = lang === 'es' ? 'EN' : 'ES';
const prefix = lang === 'es' ? '' : '/en';
const blogHref = lang === 'es' ? '/blog/' : '/en/blog/';
const servicesHref = lang === 'es' ? '/servicios/' : '/en/services/';

const navLinks = [
  { href: '#problema', label: t.nav.problem },
  { href: '#resultados', label: t.nav.results },
  { href: '#etapas', label: t.nav.methodology },
  { href: '#team', label: t.nav.team },
  { href: '#casos', label: t.nav.cases },
];
---

<header class="fixed top-0 inset-x-0 z-50 nav-header">
  <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href={lang === 'es' ? '/' : '/en/'} class="flex items-center gap-0 cursor-pointer group flex-shrink-0">
        <img
          src="https://i.imgur.com/imHxGWI.png"
          alt="Growth4U Logo"
          width="133"
          height="20"
          fetchpriority="high"
          decoding="async"
          class="h-5 md:h-6 w-auto object-contain transition-opacity group-hover:opacity-80 brightness-0 invert"
        />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-white/80 hover:text-white transition-colors px-3 py-2 text-sm font-medium whitespace-nowrap"
          >
            {link.label}
          </a>
        ))}
        <a
          href={blogHref}
          class="text-white/80 hover:text-white transition-colors px-3 py-2 text-sm font-medium"
        >
          {t.nav.blog}
        </a>

        <!-- Divider -->
        <div class="w-px h-5 bg-white/20 mx-2"></div>

        <!-- Language Toggle -->
        <a
          href={langToggleHref}
          class="lang-toggle flex items-center gap-1.5 text-white/70 hover:text-white px-2 py-1.5 text-xs font-semibold transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
          {langToggleLabel}
        </a>
      </div>

      <!-- Desktop CTA -->
      <div class="hidden md:flex items-center">
        <a
          href={bookingLink}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-[#3ecda5] text-white font-bold py-2 px-5 rounded-full text-sm transition-all duration-200 hover:bg-[#35b894] whitespace-nowrap"
        >
          {t.nav.cta}
        </a>
      </div>

      <!-- Mobile Controls -->
      <div class="md:hidden flex items-center gap-3">
        <a href={langToggleHref} class="lang-toggle text-white/80 font-semibold text-sm">
          {langToggleLabel}
        </a>
        <button
          id="mobile-menu-btn"
          class="text-white/80 hover:text-white focus:outline-none"
          aria-label="Toggle menu"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-white/10"
  >
    <div class="mx-auto max-w-7xl px-4 py-4 space-y-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-white/80 hover:text-white hover:bg-white/10 block px-3 py-2.5 rounded-lg text-base font-medium transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a
        href={blogHref}
        class="text-white/80 hover:text-white hover:bg-white/10 block px-3 py-2.5 rounded-lg text-base font-medium transition-colors"
      >
        {t.nav.blog}
      </a>
      <div class="pt-3">
        <a
          href={bookingLink}
          target="_blank"
          rel="noopener noreferrer"
          class="text-white bg-[#3ecda5] font-bold block px-3 py-2.5 rounded-full text-base text-center whitespace-nowrap"
        >
          {t.nav.cta}
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
  // Close menu when clicking a link
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });
  // Set language cookie when clicking toggle
  document.querySelectorAll('.lang-toggle').forEach(el => {
    el.addEventListener('click', () => {
      const targetLang = el.textContent?.trim() === 'EN' ? 'en' : 'es';
      document.cookie = `g4u_lang=${targetLang};path=/;max-age=31536000;SameSite=Lax`;
    });
  });
</script>
