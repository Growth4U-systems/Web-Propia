---
interface Props {
  t: any;
  bookingLink: string;
}

const { t, bookingLink } = Astro.props;
---

<section id="contacto" class="bg-[#032149] py-24 text-white">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h2 class="text-3xl md:text-5xl font-bold mb-8 tracking-tight">{t.footer.title}</h2>
    <div class="flex flex-col md:flex-row justify-center gap-5 mb-14">
      <a
        href={`mailto:${t.footer.ctaEmail}`}
        class="group flex items-center justify-center gap-2.5 bg-[#3ecda5] hover:bg-[#35b894] text-white font-bold py-4 px-8 rounded-full text-lg shadow-lg shadow-[#3ecda5]/20 hover:shadow-xl hover:shadow-[#3ecda5]/25 transition-all duration-300"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 transition-transform duration-300 group-hover:scale-110"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        {t.footer.ctaEmail}
      </a>
      <a
        href={bookingLink}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center justify-center gap-2.5 bg-transparent border border-white/20 text-white hover:bg-white/10 hover:border-white/30 font-bold py-4 px-8 rounded-full text-lg transition-all duration-300 whitespace-nowrap"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 transition-transform duration-300 group-hover:scale-110"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
        {t.footer.ctaCall}
      </a>
    </div>
    <div class="border-t border-white/10 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 mb-8 text-left">
        <div>
          <p class="text-xs font-bold uppercase tracking-wider text-white/40 mb-3">Servicios</p>
          <div class="flex flex-col gap-2">
            <a href="/servicios/geo-para-fintechs/" class="text-slate-400 hover:text-white transition-colors text-sm">GEO para Empresas Tech</a>
            <a href="/servicios/growth-marketing-fintech/" class="text-slate-400 hover:text-white transition-colors text-sm">Growth Marketing para Empresas Tech</a>
            <a href="/servicios/trust-engine/" class="text-slate-400 hover:text-white transition-colors text-sm">Trust Engine</a>
          </div>
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-wider text-white/40 mb-3">Recursos</p>
          <div class="flex flex-col gap-2">
            <a href="/recursos/" class="text-slate-400 hover:text-white transition-colors text-sm">Recursos Gratuitos</a>
            <a href="/blog/" class="text-slate-400 hover:text-white transition-colors text-sm">Blog</a>
            <a href="/casos-de-exito/" class="text-slate-400 hover:text-white transition-colors text-sm">Casos de Éxito</a>
            <a href="/equipo/" class="text-slate-400 hover:text-white transition-colors text-sm">Equipo</a>
          </div>
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-wider text-white/40 mb-3">Herramientas</p>
          <div class="flex flex-col gap-2">
            <a href="/trust-score/" class="text-slate-400 hover:text-white transition-colors text-sm">Trust Score Analyzer</a>
          </div>
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-wider text-white/40 mb-3">Legal</p>
          <div class="flex flex-col gap-2">
            <a href="/privacidad/" class="text-slate-400 hover:text-white transition-colors text-sm">{t.footer.privacy}</a>
            <a href="/cookies/" class="text-slate-400 hover:text-white transition-colors text-sm">{t.footer.terms}</a>
          </div>
        </div>
      </div>
      <div class="border-t border-white/10 pt-6 flex flex-col md:flex-row justify-between items-center text-slate-400 text-sm">
        <p>{t.footer.rights}</p>
        <div class="flex items-center gap-4 mt-4 md:mt-0">
          <a href="https://www.linkedin.com/company/growth4u/" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-colors" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://www.instagram.com/growth4u_systems/" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-colors" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
