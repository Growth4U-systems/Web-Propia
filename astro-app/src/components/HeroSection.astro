---
interface Props {
  t: any;
  bookingLink: string;
}

const { t, bookingLink } = Astro.props;

const clientNames = ['BNEXT', 'Bit2Me', 'GoCardless', 'Criptan', 'Lydia', 'Capital on Tap', 'Multimarkts', 'Multiplo'];
---

<section class="relative pt-28 pb-16 lg:pt-36 lg:pb-20 overflow-hidden bg-white">
  <!-- Animated blobs (CSS only) -->
  <div class="absolute top-0 left-1/2 w-full -translate-x-1/2 h-full z-0 pointer-events-none">
    <div class="absolute top-20 left-10 w-96 h-96 bg-[#45b6f7]/20 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-blob"></div>
    <div class="absolute top-20 right-10 w-96 h-96 bg-[#3ecda5]/20 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-blob animation-delay-2000"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Tag badge with gradient border -->
    <div class="inline-flex items-center gap-2.5 px-5 py-2.5 rounded-full hero-badge mb-8">
      <span class="flex h-2 w-2 rounded-full bg-[#3ecda5] animate-pulse"></span>
      <span class="text-sm text-[#1c3148] font-semibold tracking-wide">{t.hero.tag}</span>
    </div>

    <!-- Heading -->
    <h1 class="text-5xl md:text-7xl font-black mb-8 text-[#032149] heading-display">
      {t.hero.title} <br class="hidden md:block" />
      <span class="gradient-text">{t.hero.titleHighlight}</span>
    </h1>

    <!-- Subtitle -->
    <p class="mt-4 max-w-2xl mx-auto text-xl text-slate-600 mb-12 leading-loose">{t.hero.subtitle}</p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row justify-center gap-4">
      <a
        href={bookingLink}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center justify-center gap-2.5 bg-[#1c3148] text-white hover:bg-[#152738] font-bold py-4 px-8 rounded-full text-lg transition-all duration-300 shadow-lg shadow-[#1c3148]/15 hover:shadow-xl hover:shadow-[#1c3148]/20"
      >
        {t.hero.ctaPrimary}
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a
        href="/trust-score/"
        class="group flex items-center justify-center gap-2 bg-white text-[#3ecda5] border-2 border-[#3ecda5]/30 hover:border-[#3ecda5] hover:bg-[#3ecda5]/5 font-bold py-4 px-8 rounded-full text-lg transition-all duration-300 hover:shadow-md"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
        Mide tu confianza digital
      </a>
    </div>

  </div>
</section>

<!-- Client logos band — infinite marquee -->
<section class="relative pt-16 pb-14 mt-12 bg-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <p class="text-slate-400 text-xs font-semibold uppercase tracking-widest mb-10">{t.hero.trust}</p>
  </div>
  <div class="logo-marquee">
    <div class="logo-track">
      {[...clientNames, ...clientNames].map((name) => (
        <span class="text-sm md:text-base font-semibold text-slate-400 tracking-wide uppercase whitespace-nowrap px-8">
          {name}
        </span>
      ))}
    </div>
  </div>
</section>

<style>
  .logo-marquee {
    position: relative;
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }
  .logo-track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: marquee 20s linear infinite;
  }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
