---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';

import { getTranslations } from '../../i18n/utils';
import { getAllPosts } from '../../lib/firebase-fetch';
import { BOOKING_LINK } from '../../lib/constants';

const t = getTranslations('es');

let posts: Awaited<ReturnType<typeof getAllPosts>> = [];
try {
  posts = await getAllPosts();
} catch (e) {
  console.warn('Could not fetch blog posts at build time:', e);
}

// Pillar page slugs — aparecen en sección "Guías completas"
const PILLAR_SLUGS = new Set([
  'agencia-growth-hacking-fintech-espana',
  'agencia-influencer-marketing-financiero-fintech-espana',
  'agencia-outreach-b2b-fintech-espana',
  'agencia-afiliados-referidos-fintech-espana',
  'agencia-estrategia-gtm-fintech-espana',
  'agencia-founder-led-growth-fintech',
  'herramientas-para-crear-contenido-digital',
  'herramientas-outreach-y-prospeccion-b2b',
  'plataformas-afiliados-e-influencers',
  'automatizacion-marketing-growth-fintech',
  'herramientas-gtm-lanzamiento-producto-b2b',
  'herramientas-atribucion-marketing-fintech',
  'unit-economics-fintech-cac-ltv-payback',
  'geo-para-fintechs-guia-completa-ia-chatgpt-perplexity',
  'stack-martech-fintech-espana-guia-completa',
]);

// Secciones ordenadas: primero las guías, luego por categoría
const SECTIONS = [
  { key: 'guias',     label: 'Guías completas',  sub: 'PILLAR PAGES' },
  { key: 'Growth',    label: 'Growth',            sub: 'ÚLTIMOS POSTS' },
  { key: 'Marketing', label: 'Marketing',         sub: 'ÚLTIMOS POSTS' },
  { key: 'GEO',       label: 'GEO & Búsqueda IA', sub: 'ÚLTIMOS POSTS' },
  { key: 'Estrategia',label: 'Estrategia',        sub: 'ÚLTIMOS POSTS' },
  { key: 'Producto',  label: 'Producto',          sub: 'ÚLTIMOS POSTS' },
];

// Lead magnets para sidebar
const LEAD_MAGNETS = [
  { slug: 'cac-sostenible', title: 'El Sistema CAC Sostenible', desc: 'Reduce tu CAC sin sacrificar calidad de leads.' },
  { slug: 'meseta-de-crecimiento', title: 'Romper la Meseta de Crecimiento', desc: '4 palancas para volver a escalar.' },
  { slug: 'sistema-de-growth', title: 'De Tácticas a Sistema de Growth', desc: 'Construye un flywheel de crecimiento.' },
  { slug: 'david-vs-goliat', title: 'David vs Goliat', desc: 'Compite con grandes sin su presupuesto.' },
  { slug: 'kit-de-liberacion', title: 'Kit de Liberación del Fundador', desc: 'Deja de ser el cuello de botella.' },
  { slug: 'dashboard-de-attribution', title: 'Dashboard de Attribution', desc: 'Qué canal te trae los mejores clientes.' },
];

// Deduplica por slug (hay posts duplicados en el JSON)
const seen = new Set<string>();
const uniquePosts = posts.filter(p => {
  if (seen.has(p.slug)) return false;
  seen.add(p.slug);
  return true;
});

// Posts más recientes (no pillar) para "Novedades"
const recentPosts = uniquePosts
  .filter(p => !PILLAR_SLUGS.has(p.slug))
  .sort((a, b) => new Date(b.createdAt || 0).getTime() - new Date(a.createdAt || 0).getTime())
  .slice(0, 4);

const heroPost = recentPosts[0];
const subPosts = recentPosts.slice(1, 4);

// Los más leídos: pillar pages
const popularPosts = uniquePosts
  .filter(p => PILLAR_SLUGS.has(p.slug))
  .slice(0, 5);

function postsForSection(key: string) {
  if (key === 'guias') return uniquePosts.filter(p => PILLAR_SLUGS.has(p.slug));
  return uniquePosts.filter(p => p.category === key && !PILLAR_SLUGS.has(p.slug));
}

function formatDate(dateStr: string) {
  if (!dateStr) return '';
  try {
    return new Date(dateStr).toLocaleDateString('es-ES', {
      day: 'numeric', month: 'long', year: 'numeric',
    });
  } catch { return ''; }
}
---

<BaseLayout
  title="Blog | Growth4U"
  description="Guías y estrategias de Growth para empresas tech en España: growth hacking, outreach B2B, influencer marketing, unit economics, GEO y más."
>
  <!-- ── Blog Header ──────────────────────────────────────────────── -->
  <header class="blog-header fixed top-0 inset-x-0 z-50">
    <div class="blog-header-gradient">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-14">
          <a href="/" class="flex items-center cursor-pointer group flex-shrink-0">
            <img src="https://i.imgur.com/imHxGWI.png" alt="Growth4U Logo" width="133" height="20" class="h-5 md:h-6 w-auto object-contain brightness-0 invert transition-transform group-hover:scale-105" />
          </a>
          <div class="flex items-center gap-3">
            <button id="search-toggle" class="text-white/80 hover:text-white transition-colors p-2" aria-label="Buscar">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
              </svg>
            </button>
            <a href={BOOKING_LINK} target="_blank" rel="noopener noreferrer"
               class="hidden sm:inline-flex border-2 border-white text-white hover:bg-white hover:text-[#6351d5] font-bold py-1.5 px-5 rounded-full text-sm transition-all duration-300">
              Agenda tu demo
            </a>
          </div>
        </div>
      </div>
    </div>

    <nav class="blog-header-gradient-sub">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="flex items-center gap-1 h-10 overflow-x-auto" style="scrollbar-width:none;-ms-overflow-style:none;">
          {SECTIONS.map((section) => (
            <a href={`#section-${section.key}`}
               class="blog-cat-link whitespace-nowrap px-3 md:px-4 py-1.5 text-xs md:text-sm font-medium text-white/80 hover:text-white hover:bg-white/15 rounded-full transition-all duration-200"
               data-section={section.key}>
              {section.label}
            </a>
          ))}
        </div>
      </div>
    </nav>

    <div id="search-bar" class="hidden bg-white border-b border-slate-200 shadow-sm">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3 flex items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input id="blog-search" type="text" placeholder="Buscar artículos..."
          class="flex-1 text-base text-[#032149] placeholder-slate-400 outline-none bg-transparent" />
        <button id="search-close" class="text-slate-400 hover:text-slate-600 p-1" aria-label="Cerrar búsqueda">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <!-- ══════════════════════════════════════════════════════════════════ -->
  <!-- CONTENIDO                                                        -->
  <!-- ══════════════════════════════════════════════════════════════════ -->
  <main class="pt-28 pb-24 px-4 bg-slate-50">
    <div class="max-w-6xl mx-auto">

      <!-- Resultados de búsqueda -->
      <div id="search-results" class="hidden mb-16">
        <div class="flex items-baseline gap-3 mb-6">
          <h2 class="text-xl font-bold text-[#032149]">Resultados</h2>
          <span id="search-count" class="text-sm text-slate-400"></span>
          <button id="clear-search" class="ml-auto text-sm text-[#6351d5] hover:underline">Limpiar búsqueda</button>
        </div>
        <div id="search-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"></div>
      </div>

      <!-- ── NOVEDADES ─────────────────────────────────────────────── -->
      {heroPost && (
        <section class="mb-10" id="section-novedades">
          <h2 class="text-lg font-extrabold text-[#032149] mb-4 uppercase tracking-wide">Novedades</h2>

          <div class="grid grid-cols-1 lg:grid-cols-[1.2fr_1fr] gap-5">
            <!-- Hero post: imagen + card blanca debajo -->
            <a href={`/blog/${heroPost.slug}/`} class="group/hero block rounded-xl overflow-hidden bg-white border border-slate-100 hover:shadow-lg transition-all duration-300">
              <div class="aspect-[16/10] bg-slate-100 overflow-hidden">
                {heroPost.image ? (
                  <img src={heroPost.image} alt={heroPost.title} class="object-cover w-full h-full group-hover/hero:scale-105 transition-transform duration-500" />
                ) : (
                  <div class="w-full h-full bg-gradient-to-br from-[#032149] to-[#0faec1]" />
                )}
              </div>
              <div class="p-4">
                <span class="text-[10px] font-bold text-[#6351d5] uppercase tracking-widest">{heroPost.category}</span>
                <h3 class="text-base font-extrabold text-[#032149] group-hover/hero:text-[#6351d5] transition-colors leading-snug mt-1 line-clamp-2">{heroPost.title}</h3>
                <p class="text-slate-500 text-xs line-clamp-2 mt-1">{heroPost.excerpt}</p>
              </div>
            </a>

            <!-- 3 sub-posts: fila horizontal con thumbnail + texto -->
            <div class="flex flex-col gap-3">
              {subPosts.map((post) => (
                <a href={`/blog/${post.slug}/`} class="group/sub flex gap-3 bg-white rounded-lg border border-slate-100 hover:shadow-md transition-all duration-300 p-2.5">
                  <div class="flex-shrink-0 w-28 h-20 rounded-md overflow-hidden bg-slate-100">
                    {post.image ? (
                      <img src={post.image} alt={post.title} class="object-cover w-full h-full group-hover/sub:scale-105 transition-transform duration-500" loading="lazy" />
                    ) : (
                      <div class="w-full h-full bg-gradient-to-br from-[#032149] to-[#0faec1]" />
                    )}
                  </div>
                  <div class="flex flex-col justify-center min-w-0">
                    <span class="text-[10px] font-bold text-[#6351d5] uppercase tracking-widest">{post.category}</span>
                    <h3 class="font-bold text-sm text-[#032149] group-hover/sub:text-[#6351d5] transition-colors line-clamp-2 leading-snug mt-0.5">{post.title}</h3>
                    <span class="text-slate-400 text-[11px] mt-1">{formatDate(post.createdAt)}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>
      )}

      <!-- ── DESTACADOS: contenido + sidebar ───────────────────────── -->
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-8">

        <!-- Columna principal -->
        <div id="sections-container">
          {SECTIONS.map((section) => {
            const sectionPosts = postsForSection(section.key);
            if (sectionPosts.length === 0) return null;
            const isGuias = section.key === 'guias';
            return (
              <div id={`section-${section.key}`} class="mb-12 section-block scroll-mt-32" data-section={section.key}>
                <div class="mb-5">
                  <h2 class="text-xl font-extrabold text-[#032149] uppercase tracking-wide">{section.label}</h2>
                  <p class="text-xs font-bold text-slate-400 tracking-widest uppercase mt-0.5">{section.sub}</p>
                </div>

                {isGuias ? (
                  /* Guías: carrusel */
                  <div class="relative group/carousel">
                    <button class="carousel-prev absolute -left-4 top-1/2 -translate-y-1/2 z-10 w-8 h-8 rounded-full bg-white border border-slate-200 shadow flex items-center justify-center text-[#032149] hover:bg-[#6351d5] hover:text-white transition-all opacity-0 group-hover/carousel:opacity-100" aria-label="anterior">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="m15 18-6-6 6-6"/></svg>
                    </button>
                    <div class="carousel-track flex gap-3 overflow-x-auto pb-2 scroll-smooth" style="scrollbar-width:none;-ms-overflow-style:none;">
                      {sectionPosts.map((post) => (
                        <a href={`/blog/${post.slug}/`}
                           data-title={post.title.toLowerCase()}
                           data-excerpt={(post.excerpt || '').toLowerCase()}
                           class="post-card flex-none w-48 bg-white rounded-lg overflow-hidden border border-slate-100 hover:shadow-md transition-all duration-300 group/card">
                          <div class="aspect-[4/3] bg-slate-100 overflow-hidden">
                            {post.image ? (
                              <img src={post.image} alt={post.title} class="object-cover w-full h-full group-hover/card:scale-105 transition-transform duration-500" loading="lazy" />
                            ) : (
                              <div class="w-full h-full bg-gradient-to-br from-[#032149] to-[#0faec1]" />
                            )}
                          </div>
                          <div class="p-2.5">
                            <h3 class="font-semibold text-xs text-[#032149] group-hover/card:text-[#6351d5] transition-colors line-clamp-2 leading-snug">{post.title}</h3>
                            <span class="text-[#6351d5] text-[11px] font-medium mt-1 inline-block">Leer más</span>
                          </div>
                        </a>
                      ))}
                    </div>
                    <button class="carousel-next absolute -right-4 top-1/2 -translate-y-1/2 z-10 w-8 h-8 rounded-full bg-white border border-slate-200 shadow flex items-center justify-center text-[#032149] hover:bg-[#6351d5] hover:text-white transition-all opacity-0 group-hover/carousel:opacity-100" aria-label="siguiente">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
                    </button>
                  </div>
                ) : (
                  /* Categorías: filas horizontales compactas */
                  <div class="section-grid">
                    <div class="flex flex-col gap-3">
                      {sectionPosts.map((post, i) => (
                        <a href={`/blog/${post.slug}/`}
                           data-title={post.title.toLowerCase()}
                           data-excerpt={(post.excerpt || '').toLowerCase()}
                           class:list={[
                             'post-card flex gap-3 bg-white rounded-lg border border-slate-100 hover:shadow-md transition-all duration-300 p-2.5 group/card',
                             i >= 6 && 'hidden extra-card',
                           ]}>
                          <div class="flex-shrink-0 w-28 h-20 rounded-md overflow-hidden bg-slate-100">
                            {post.image ? (
                              <img src={post.image} alt={post.title} class="object-cover w-full h-full group-hover/card:scale-105 transition-transform duration-500" loading="lazy" />
                            ) : (
                              <div class="w-full h-full bg-gradient-to-br from-[#032149] to-[#0faec1]" />
                            )}
                          </div>
                          <div class="flex flex-col justify-center min-w-0">
                            <span class="text-[10px] font-bold text-[#6351d5] uppercase tracking-widest">{post.category}</span>
                            <h3 class="font-bold text-sm text-[#032149] group-hover/card:text-[#6351d5] transition-colors line-clamp-2 leading-snug mt-0.5">{post.title}</h3>
                            <p class="text-slate-400 text-xs line-clamp-1 mt-0.5">{post.excerpt}</p>
                          </div>
                        </a>
                      ))}
                    </div>
                    {sectionPosts.length > 6 && (
                      <div class="text-center mt-4">
                        <button class="show-more-btn text-[#6351d5] font-semibold text-sm hover:underline">
                          Ver todos ({sectionPosts.length} artículos)
                        </button>
                      </div>
                    )}
                  </div>
                )}
              </div>
            );
          })}
        </div>

        <!-- ── Sidebar ────────────────────────────────────────────── -->
        <aside class="hidden lg:block">
          <div class="sticky top-28 space-y-6">

            <!-- Artículos más leídos -->
            <div class="rounded-xl overflow-hidden shadow-sm">
              <div class="bg-[#6351d5] text-white text-center font-bold py-2.5 px-4 text-sm">
                Artículos más leídos
              </div>
              <div class="bg-white divide-y divide-slate-100">
                {popularPosts.map((post) => (
                  <a href={`/blog/${post.slug}/`} class="block px-4 py-3 hover:bg-slate-50 transition-colors group/pop">
                    <p class="font-semibold text-sm text-[#032149] group-hover/pop:text-[#6351d5] transition-colors line-clamp-2 leading-snug">{post.title}</p>
                    <span class="text-[#6351d5] text-xs font-medium mt-1 inline-block">Leer artículo</span>
                  </a>
                ))}
              </div>
            </div>

            <!-- Recursos gratuitos -->
            <div class="rounded-xl overflow-hidden shadow-sm">
              <div class="bg-[#0faec1] text-white text-center font-bold py-2.5 px-4 text-sm">
                Recursos gratuitos
              </div>
              <div class="bg-white divide-y divide-slate-100">
                {LEAD_MAGNETS.slice(0, 4).map((lm) => (
                  <a href={`/recursos/${lm.slug}/`} class="block px-4 py-3 hover:bg-slate-50 transition-colors group/lm">
                    <p class="font-semibold text-sm text-[#032149] group-hover/lm:text-[#0faec1] transition-colors leading-snug">{lm.title}</p>
                    <p class="text-slate-400 text-xs mt-0.5 line-clamp-1">{lm.desc}</p>
                  </a>
                ))}
                <a href="/recursos/" class="block px-4 py-2.5 text-center text-[#0faec1] text-xs font-semibold hover:underline">
                  Ver todos los recursos
                </a>
              </div>
            </div>

            <!-- CTA -->
            <div class="bg-gradient-to-br from-[#032149] to-[#6351d5] rounded-xl p-5 text-center">
              <p class="text-white font-bold mb-1">¿Listo para escalar?</p>
              <p class="text-white/60 text-xs mb-4">Consulta estratégica gratuita de 30 min.</p>
              <a href={BOOKING_LINK} target="_blank" rel="noopener noreferrer"
                 class="inline-block bg-white text-[#6351d5] font-bold py-2 px-5 rounded-full text-sm hover:shadow-lg transition-all">
                Agenda tu demo
              </a>
            </div>

          </div>
        </aside>

      </div>
    </div>
  </main>

  <Footer t={t} bookingLink={BOOKING_LINK} />

  <script>
    // ── Carruseles ──────────────────────────────────────────────────────
    document.querySelectorAll<HTMLElement>('.relative.group\\/carousel').forEach(wrapper => {
      const track = wrapper.querySelector<HTMLElement>('.carousel-track')!;
      const prev  = wrapper.querySelector<HTMLButtonElement>('.carousel-prev')!;
      const next  = wrapper.querySelector<HTMLButtonElement>('.carousel-next')!;
      const scroll = (dir: number) => {
        const card = track.querySelector<HTMLElement>('.post-card');
        const step = card ? card.offsetWidth + 16 : 272;
        track.scrollBy({ left: dir * step, behavior: 'smooth' });
      };
      prev?.addEventListener('click', () => scroll(-1));
      next?.addEventListener('click', () => scroll(1));
    });

    // ── "Ver más" ───────────────────────────────────────────────────────
    document.querySelectorAll<HTMLButtonElement>('.show-more-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const grid = btn.closest('.section-grid')!;
        grid.querySelectorAll<HTMLElement>('.extra-card').forEach(c => c.classList.remove('hidden'));
        btn.closest('div')!.remove();
      });
    });

    // ── Búsqueda ────────────────────────────────────────────────────────
    const searchToggle = document.getElementById('search-toggle')!;
    const searchBar    = document.getElementById('search-bar')!;
    const searchClose  = document.getElementById('search-close')!;
    const input        = document.getElementById('blog-search') as HTMLInputElement;
    const clearBtn     = document.getElementById('clear-search')!;
    const resultsBox   = document.getElementById('search-results')!;
    const sectionsBox  = document.getElementById('sections-container')!;
    const searchGrid   = document.getElementById('search-grid')!;
    const countEl      = document.getElementById('search-count')!;

    searchToggle.addEventListener('click', () => {
      searchBar.classList.toggle('hidden');
      if (!searchBar.classList.contains('hidden')) input.focus();
    });
    searchClose.addEventListener('click', () => { searchBar.classList.add('hidden'); clearSearch(); });

    const allCards = Array.from(document.querySelectorAll<HTMLElement>('#sections-container .post-card'));

    function doSearch() {
      const q = input.value.trim().toLowerCase();
      if (!q) { clearSearch(); return; }
      const matches = allCards.filter(c => (c.dataset.title||'').includes(q) || (c.dataset.excerpt||'').includes(q));
      searchGrid.innerHTML = '';
      matches.forEach(c => {
        const clone = c.cloneNode(true) as HTMLElement;
        clone.classList.remove('flex-none', 'w-48', 'hidden', 'extra-card');
        searchGrid.appendChild(clone);
      });
      countEl.textContent = `${matches.length} resultado${matches.length !== 1 ? 's' : ''}`;
      resultsBox.classList.remove('hidden');
      sectionsBox.classList.add('hidden');
    }

    function clearSearch() {
      input.value = '';
      resultsBox.classList.add('hidden');
      sectionsBox.classList.remove('hidden');
    }

    input.addEventListener('keydown', e => { if (e.key === 'Enter') doSearch(); });
    input.addEventListener('input', () => { if (!input.value) clearSearch(); else doSearch(); });
    clearBtn.addEventListener('click', () => { clearSearch(); searchBar.classList.add('hidden'); });

    // ── Active category on scroll ───────────────────────────────────────
    const catLinks = document.querySelectorAll<HTMLAnchorElement>('.blog-cat-link');
    const sectionEls = document.querySelectorAll<HTMLElement>('.section-block');
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const key = (entry.target as HTMLElement).dataset.section;
          catLinks.forEach(link => {
            const match = link.dataset.section === key;
            link.classList.toggle('bg-white/20', match);
            link.classList.toggle('text-white', match);
            link.classList.toggle('text-white/80', !match);
          });
        }
      });
    }, { rootMargin: '-30% 0px -60% 0px' });
    sectionEls.forEach(el => obs.observe(el));
  </script>

  <style>
    .carousel-track::-webkit-scrollbar { display: none; }
    .blog-header-gradient-sub div::-webkit-scrollbar { display: none; }
    .blog-header-gradient {
      background: linear-gradient(135deg, #6351d5 0%, #3f45fe 40%, #45b6f7 75%, #0faec1 100%);
    }
    .blog-header-gradient-sub {
      background: linear-gradient(135deg, #5242b8 0%, #3539d6 40%, #3a9fd6 75%, #0d9aaa 100%);
    }
  </style>
</BaseLayout>
