        </div>
        <div style="background:white;border-radius:8px;padding:14px;border-left:4px solid #22c55e">
          <p style="color:#032149;font-size:13px;font-weight:700;margin:0 0 4px 0">registration_completed</p>
          <p style="color:#64748b;font-size:12px;margin:0">Registro completado. Props: partner, user_id, email_domain</p>
        </div>
        <div style="background:white;border-radius:8px;padding:14px;border-left:4px solid #a855f7">
          <p style="color:#032149;font-size:13px;font-weight:700;margin:0 0 4px 0">first_investment</p>
          <p style="color:#64748b;font-size:12px;margin:0">Primera inversión real. Props: partner, amount, investment_id</p>
        </div>
