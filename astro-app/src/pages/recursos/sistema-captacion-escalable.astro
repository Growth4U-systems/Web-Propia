        <div style="color:#3ecda5;font-size:28px;font-weight:800">19.305 €</div>
        <div style="color:rgba(255,255,255,0.7);font-size:12px;margin-top:4px">Inversión total</div>
      </div>
      <div style="background:rgba(255,255,255,0.1);border-radius:10px;padding:16px;text-align:center">
        <div style="color:#3ecda5;font-size:28px;font-weight:800">269</div>
        <div style="color:rgba(255,255,255,0.7);font-size:12px;margin-top:4px">Registros</div>
      </div>
