    </div>

    <div style="background:linear-gradient(135deg,#1a1a2e,#16213e);border-radius:12px;padding:20px;border:1px solid #334155">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px">
        <div style="width:24px;height:24px;background:linear-gradient(135deg,#d4a574,#c9956b);border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <p style="color:white;font-size:14px;font-weight:700;margin:0">Con Claude Code:</p>
