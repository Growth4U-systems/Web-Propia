      <pre style="background:#1e293b;color:#e2e8f0;padding:16px;border-radius:8px;font-size:13px;overflow-x:auto;margin:0"><code>// En cada landing de influencer
posthog.capture('partner_landing_view', {
  partner: 'jf-calero',
  utm_source: 'youtube',
  utm_campaign: 'crowdfunding-q1'
});

// Al hacer click en CTA
posthog.capture('partner_cta_click', {
  partner: 'jf-calero',
  button_position: 'hero'
});

// Después del registro (server-side o webhook)
posthog.capture('registration_completed', {
  partner: 'jf-calero',
  user_id: 'usr_12345'
});</code></pre>
    </div>

    <div style="background:linear-gradient(135deg,#1a1a2e,#16213e);border-radius:12px;padding:20px;border:1px solid #334155">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px">
