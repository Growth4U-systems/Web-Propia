        <div style="color:white;font-size:14px;font-weight:700;margin-bottom:4px">Landings</div>
        <div style="color:#94a3b8;font-size:12px">Una URL única por influencer</div>
      </div>
      <div style="background:rgba(255,255,255,0.1);border-radius:10px;padding:16px;text-align:center;border:1px solid rgba(255,255,255,0.1)">
        <div style="color:#3ecda5;font-size:24px;font-weight:800;margin-bottom:4px">2</div>
        <div style="color:white;font-size:14px;font-weight:700;margin-bottom:4px">Tracking</div>
        <div style="color:#94a3b8;font-size:12px">Eventos PostHog en cada paso</div>
      </div>
      <div style="background:rgba(255,255,255,0.1);border-radius:10px;padding:16px;text-align:center;border:1px solid rgba(255,255,255,0.1)">
        <div style="color:#3ecda5;font-size:24px;font-weight:800;margin-bottom:4px">3</div>
        <div style="color:white;font-size:14px;font-weight:700;margin-bottom:4px">CRM</div>
        <div style="color:#94a3b8;font-size:12px">API para atribuir conversiones</div>
      </div>
      <div style="background:rgba(255,255,255,0.1);border-radius:10px;padding:16px;text-align:center;border:1px solid rgba(255,255,255,0.1)">
        <div style="color:#3ecda5;font-size:24px;font-weight:800;margin-bottom:4px">4</div>
        <div style="color:white;font-size:14px;font-weight:700;margin-bottom:4px">Dashboard</div>
        <div style="color:#94a3b8;font-size:12px">Métricas y decisiones</div>
