const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Recursos', item: `${SITE_URL}/recursos/` },
    { '@type': 'ListItem', position: 3, name: title, item: `${SITE_URL}/recursos/${slug}/` },
  ],
};
---

<BaseLayout
  title={`${title} | Growth4U`}
  description={description}
  canonical={`${SITE_URL}/recursos/${slug}/`}
  ogImage={generateOgImage(title)}
  jsonLd={[breadcrumbSchema]}
>
  <main class="min-h-screen bg-white">
    <section class="bg-[#ece7de] pt-20 pb-14 relative overflow-hidden">
      <!-- Claude sparkle decorations -->
      <div class="absolute top-10 right-10 opacity-10">
        <svg width="160" height="160" viewBox="0 0 100 100" fill="none">
          <path d="M50 0 L53 47 L100 50 L53 53 L50 100 L47 53 L0 50 L47 47 Z" fill="#c9956b"/>
        </svg>
      </div>
      <div class="absolute bottom-10 left-8 opacity-5">
        <svg width="100" height="100" viewBox="0 0 100 100" fill="none">
          <path d="M50 0 L53 47 L100 50 L53 53 L50 100 L47 53 L0 50 L47 47 Z" fill="#c9956b"/>
        </svg>
      </div>

      <div class="max-w-5xl mx-auto px-4 relative z-10">
        <div class="flex items-center gap-2 mb-6">
          <a href="/" class="text-[#6b5c4c]/60 hover:text-[#6b5c4c] text-sm transition-colors">Growth4U</a>
          <span class="text-[#6b5c4c]/30">/</span>
          <span class="text-[#6b5c4c]/60 text-sm">Recursos</span>
        </div>

        <!-- Claude Code badge -->
        <div class="inline-flex items-center gap-2 bg-[#c9956b]/20 border border-[#c9956b]/30 rounded-full px-4 py-2 mb-6">
          <svg width="16" height="16" viewBox="0 0 100 100" fill="none">
            <path d="M50 10 L53 47 L90 50 L53 53 L50 90 L47 53 L10 50 L47 47 Z" fill="#c9956b"/>
          </svg>
          <span class="text-[#8b6914] text-sm font-semibold">Guía práctica con Claude Code</span>
        </div>

        <h1 class="text-4xl md:text-5xl font-extrabold text-[#1a1a1a] mb-6 leading-tight">{title}</h1>
        <p class="text-xl text-[#5c5347] leading-relaxed mb-8 max-w-3xl">{description}</p>

        <!-- Logos: Growth4U + Claude -->
        <div class="flex items-center gap-6 mb-8">
          <div class="flex items-center gap-3 bg-white/50 backdrop-blur border border-[#c9956b]/20 rounded-xl px-5 py-3">
            <img src="https://i.imgur.com/imHxGWI.png" alt="Growth4U" class="h-5" />
            <span class="text-[#c9956b]/50 text-lg">×</span>
            <div class="flex items-center gap-2">
              <svg width="20" height="20" viewBox="0 0 100 100" fill="none">
                <path d="M50 10 L53 47 L90 50 L53 53 L50 90 L47 53 L10 50 L47 47 Z" fill="#c9956b"/>
              </svg>
              <span class="text-[#1a1a1a] font-bold text-lg" style="font-family: Georgia, serif">Claude</span>
            </div>
