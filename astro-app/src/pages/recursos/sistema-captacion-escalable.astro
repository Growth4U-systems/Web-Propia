        <div style="color:rgba(255,255,255,0.6);font-size:11px;margin-top:2px">Canales activados</div>
      </div>
    </div>
  </div>

  <!-- Tabla completa de canales -->
  <div style="background:white;border-radius:16px;padding:28px;margin-bottom:28px;border:1px solid #e2e8f0">
    <h2 style="color:#032149;font-size:22px;font-weight:800;margin-bottom:16px">Rendimiento por canal</h2>

    <div style="overflow-x:auto;margin-bottom:20px">
      <table style="width:100%;border-collapse:collapse;font-size:13px">
