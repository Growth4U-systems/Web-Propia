---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TrustScoreAnalyzer from '../../../react/TrustScoreAnalyzer';
import { SITE_URL } from '../../../lib/constants';

const title = 'Trust Score Analyzer';
const description = 'Descubre en 2 minutos cómo te perciben Google, las IAs y tus potenciales clientes. Análisis gratuito de 6 pilares de confianza digital.';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Recursos', item: `${SITE_URL}/recursos/` },
    { '@type': 'ListItem', position: 3, name: title, item: `${SITE_URL}/recursos/trust-score/` },
  ],
};

const softwareAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Trust Score Analyzer',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
  author: { '@type': 'Organization', name: 'Growth4U', url: SITE_URL },
  description,
};
---

<BaseLayout
  title={`${title} — Diagnóstico Gratuito | Growth4U`}
  description={description}
  canonical={`${SITE_URL}/recursos/trust-score/`}
  jsonLd={[breadcrumbSchema, softwareAppSchema]}
>
  <main class="min-h-screen bg-white">
    <section class="bg-[#032149] pt-20 pb-14">
      <div class="max-w-3xl mx-auto px-4">
        <div class="flex items-center gap-2 mb-6">
          <a href="/" class="text-white/50 hover:text-white text-sm transition-colors">Growth4U</a>
          <span class="text-white/30">/</span>
          <a href="/recursos/" class="text-white/50 hover:text-white text-sm transition-colors">Recursos</a>
          <span class="text-white/30">/</span>
          <span class="text-white/80 text-sm">Trust Score</span>
        </div>
        <span class="inline-block px-3 py-1 bg-[#0faec1]/30 text-[#7dd3e8] rounded-full text-xs font-bold uppercase tracking-wider mb-6">
          Herramienta Gratuita
        </span>
        <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-6 leading-tight">{title}</h1>
        <p class="text-xl text-slate-300 leading-relaxed mb-8">{description}</p>
        <div class="flex flex-wrap items-center gap-6 text-slate-400 text-sm">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>100% gratuito</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>Sin registro previo</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>Resultado en 2 min</span>
          </div>
        </div>
      </div>
    </section>
    <section class="max-w-3xl mx-auto px-4 py-12 pb-20">
      <TrustScoreAnalyzer client:only="react" />
    </section>
  </main>
</BaseLayout>
