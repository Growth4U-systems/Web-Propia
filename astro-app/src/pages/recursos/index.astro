const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Recursos', item: `${SITE_URL}/recursos/` },
  ],
};
---

<BaseLayout
  title={`${title} | Growth4U`}
  description={description}
  canonical={`${SITE_URL}/recursos/`}
  jsonLd={[breadcrumbSchema]}
>
  <main class="min-h-screen bg-white">
    <!-- Hero -->
    <section class="bg-[#032149] pt-20 pb-14">
      <div class="max-w-5xl mx-auto px-4">
        <div class="flex items-center gap-2 mb-6">
          <a href="/" class="text-white/50 hover:text-white text-sm transition-colors">Growth4U</a>
          <span class="text-white/30">/</span>
          <span class="text-white/80 text-sm">Recursos</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-6 leading-tight">
          Recursos Gratuitos
        </h1>
        <p class="text-xl text-slate-300 leading-relaxed max-w-2xl">
          Frameworks, playbooks y herramientas probadas con fintechs y SaaS reales. Sin teoría. Sin fluff. Desbloquea cada recurso con tu email y accede al contenido completo.
        </p>
      </div>
    </section>

    <!-- Grid de recursos -->
    <section class="max-w-5xl mx-auto px-4 py-12 pb-20">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {recursos.map((r) => (
          <a
            href={r.slug === 'trust-score' ? '/trust-score/' : `/recursos/${r.slug}/`}
            class="group block bg-white rounded-2xl border border-slate-200 hover:border-[#3ecda5]/40 hover:shadow-lg transition-all duration-200 overflow-hidden"
          >
            <div class="p-6">
              <span
                class="inline-block px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider mb-4"
                style={`background:${r.color}20;color:${r.color}`}
              >
                {r.tag}
              </span>
              <h2 class="text-lg font-bold text-[#032149] mb-3 group-hover:text-[#3ecda5] transition-colors leading-snug">
                {r.title}
              </h2>
              <p class="text-sm text-slate-500 leading-relaxed mb-4">
                {r.description}
              </p>
              <div class="flex items-center gap-2 text-[#3ecda5] text-sm font-semibold">
                <span>Acceder gratis</span>
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- CTA final -->
      <div class="mt-16 text-center bg-gradient-to-br from-[#032149] to-[#3ecda5] rounded-2xl p-10">
        <h2 class="text-2xl md:text-3xl font-extrabold text-white mb-4">
          ¿Prefieres que lo hagamos juntos?
        </h2>
        <p class="text-slate-300 text-lg mb-8 max-w-xl mx-auto">
          Agenda una sesión de 30 minutos para ver cómo aplicar estos frameworks a tu caso específico.
        </p>
        <a
          href="https://now.growth4u.io/widget/bookings/growth4u_demo"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-white text-[#3ecda5] font-bold text-base px-8 py-4 rounded-lg hover:bg-slate-50 transition-colors"
        >
          Agendar sesión gratuita
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
